---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Impressum">
	<header class="bg-zinc-900 text-white py-12 px-4 border-b-4 border-red-600">
		<div class="max-w-4xl mx-auto">
			<h1 class="text-3xl md:text-5xl font-black uppercase tracking-tight">Impressum</h1>
			<p class="text-gray-400 mt-2 text-sm md:text-base">Rechtliche Angaben gemäß § 5 TMG</p>
		</div>
	</header>

	<main class="max-w-4xl mx-auto px-4 py-12 flex-grow text-gray-700 leading-relaxed space-y-8">
		
		<section class="space-y-2">
			<h2 class="text-xl font-bold text-black uppercase tracking-wide">Angaben gemäß § 5 TMG</h2>
			<p class="font-bold text-gray-900">BV Brambauer 13/45 e.V.</p>
			<p>Diebecker Weg 29</p>
			<p>44536 Lünen</p>
		</section>

		<section class="space-y-2">
			<h2 class="text-xl font-bold text-black uppercase tracking-wide">Vertreten durch den Vorstand</h2>
			<p>1. Geschäftsführer: Basdorf, Oliver Maximilian, Lünen</p>
			<p>2. Vorsitzender: Smuda, Werner, Lünen</p>
			<p>3. Vorsitzender: Izmirli, Baris, Lünen</p>
			<p>4. Vorsitzender: Jöres, Dariusz, Lünen</p>
			<p>1. Kassierer: Prediger, Klaus, Selm</p>
			<p class="text-sm italic text-gray-500">Der Verein wird von dem 1. oder 2. Vorsitzenden und einem weiteren Mitglied des geschäftsführenden Vorstandes
vertreten.</p>
		</section>

		<section class="space-y-2">
			<h2 class="text-xl font-bold text-black uppercase tracking-wide">Kontakt</h2>
			<p>Telefon: [Telefonnummer Geschäftsstelle/Vorstand]</p>
			<p>E-Mail: <a href="mailto:info@bv-brambauer.de" class="text-red-600 hover:underline">info[at]bv-brambauer.de</a></p>
		</section>

		<section class="space-y-2">
			<h2 class="text-xl font-bold text-black uppercase tracking-wide">Registereintrag</h2>
			<p>Eintragung im Vereinsregister.</p>
			<p>Registergericht: Amtsgericht Dortmund</p>
			<p>Registernummer: VR 20238</p>
		</section>

		<section class="space-y-2">
			<h2 class="text-xl font-bold text-black uppercase tracking-wide">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
			<p>Basdorf, Oliver Maximilian, Lünen</p>
			<p>Anschrift wie oben</p>
		</section>

	</main>
</MainLayout>