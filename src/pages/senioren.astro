---
// src/pages/senioren.astro
// Wir importieren unser neues Master-Layout
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Unsere Senioren">
    
    <header class="bg-zinc-900 text-white py-12 px-4 border-b-4 border-red-600">
        <div class="max-w-6xl mx-auto">
            <h1 class="text-3xl md:text-5xl font-black uppercase tracking-tight">Unsere Senioren</h1>
            <p class="text-gray-400 mt-2 text-base md:text-lg">Von der Kreisliga A bis zu unseren Traditions-Kickern – der Seniorenfußball beim BVB.</p>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-12 flex-grow">
        <!-- Grid für die 3 Haupt-Mannschaften -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
            
            <!-- SECTION: 1. Mannschaft -->
            <section class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col justify-between">
                <div>
                    <!-- FIX: bg-zinc-900 statt bg-red-600, dafür eine rote Kante (border-t-4 border-red-600) -->
                    <div class="p-6 bg-zinc-900 text-white border-t-4 border-red-600">
                        <span class="text-xs font-bold uppercase tracking-wider text-red-500">A-Liga Dortmund</span>
                        <h2 class="text-2xl font-black uppercase mt-1">1. Mannschaft</h2>
                    </div>
                    <div class="p-6 space-y-4">
                        <p class="text-gray-600 text-sm">Unser Aushängeschild im Herrenbereich. Das Team kämpft jede Woche in der Kreisliga A2 um wichtige Punkte für den Aufstieg.</p>
                        <div class="border-t border-gray-100 pt-4 text-sm">
                            <p class="font-bold text-gray-500 uppercase text-xs tracking-wider">Trainingszeiten</p>
                            <p class="text-gray-900 font-medium mt-1">Dienstag & Donnerstag: 19:00 - 20:30 Uhr</p>
                        </div>
                        <div class="border-t border-gray-100 pt-4 text-sm">
                            <p class="font-bold text-gray-500 uppercase text-xs tracking-wider">Trainer-Team</p>
                            <p class="text-gray-900 font-medium mt-1">Cheftrainer (Name folgt)</p>
                        </div>
                    </div>
                </div>
                <div class="p-6 bg-gray-50 border-t border-gray-150">
                    <!-- Geänderter Link: Springt jetzt sanft nach unten zum interaktiven Live-Bereich -->
                    <a href="#live-ticker-erste" class="block text-center bg-zinc-900 hover:bg-red-600 text-white text-sm font-bold py-2.5 rounded transition uppercase tracking-wider text-xs">Tabelle & Spielplan live</a>
                </div>
            </section>

            <!-- SECTION: 2. Mannschaft -->
            <section class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col justify-between">
                <div>
                    <div class="p-6 bg-zinc-900 text-white">
                        <span class="text-xs font-bold uppercase tracking-wider bg-white/10 px-2.5 py-1 rounded">B-Liga Dortmund</span>
                        <h2 class="text-2xl font-black uppercase mt-2">2. Mannschaft</h2>
                    </div>
                    <div class="p-6 space-y-4">
                        <p class="text-gray-600 text-sm">Unser starker Unterbau (BV Brambauer II). Hier reifen junge Talente heran und erfahrene Spieler sorgen für die nötige Stabilität.</p>
                        <div class="border-t border-gray-100 pt-4 text-sm">
                            <p class="font-bold text-gray-500 uppercase text-xs tracking-wider">Trainingszeiten</p>
                            <p class="text-gray-900 font-medium mt-1">Dienstag & Donnerstag: 19:00 - 20:30 Uhr</p>
                        </div>
                        <div class="border-t border-gray-100 pt-4 text-sm">
                            <p class="font-bold text-gray-500 uppercase text-xs tracking-wider">Trainer-Team</p>
                            <p class="text-gray-900 font-medium mt-1">Trainer (Name folgt)</p>
                        </div>
                    </div>
                </div>
                <div class="p-6 bg-gray-50 border-t border-gray-150">
                    <a href="#live-ticker-zweite" class="block text-center bg-zinc-900 hover:bg-red-600 text-white text-sm font-bold py-2.5 rounded transition uppercase tracking-wider text-xs">Tabelle & Spielplan live</a>
                </div>
            </section>

            <!-- SECTION: Alte Herren -->
            <section class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col justify-between">
                <div>
                    <div class="p-6 bg-gray-100 text-gray-900 border-b border-gray-200">
                        <span class="text-xs font-bold uppercase tracking-wider bg-gray-200 text-gray-700 px-2.5 py-1 rounded">Freizeit & Pokal</span>
                        <h2 class="text-2xl font-black uppercase mt-2 text-black">Alte Herren (Ü32 - Ü50)</h2>
                    </div>
                    <div class="p-6 space-y-4">
                        <p class="text-gray-600 text-sm">Die Traditions-Kicker des BVB. Unsere Ü32, Ü40 und Ü50 Mannschaften kicken in Pokalrunden, Turnieren und halten die Geselligkeit hoch.</p>
                        <div class="border-t border-gray-100 pt-4 text-sm">
                            <p class="font-bold text-gray-500 uppercase text-xs tracking-wider">Trainingszeiten (Ü50 / Ü32)</p>
                            <p class="text-gray-900 font-medium mt-1">Mittwoch: ab 18:30 Uhr</p>
                        </div>
                        <div class="border-t border-gray-100 pt-4 text-sm">
                            <p class="font-bold text-gray-500 uppercase text-xs tracking-wider">Fokus</p>
                            <p class="text-gray-900 font-medium mt-1">Freundschaftsspiele, Kreispokal & Vereinskultur</p>
                        </div>
                    </div>
                </div>
                <div class="p-6 bg-gray-50 border-t border-gray-150">
                    <a href="mailto:kontakt@bv-brambauer.de" class="block text-center bg-zinc-900 hover:bg-red-600 text-white text-sm font-bold py-2.5 rounded transition uppercase tracking-wider text-xs">Ansprechpartner kontaktieren</a>
                </div>
            </section>
        </div>

        <hr class="border-gray-200 my-12" />

        <!-- NEU: DER INTERAKTIVE LIVE-DATA BEREICH -->
        <div class="space-y-16">
            
            <!-- Live-Bereich: 1. Mannschaft -->
            <div id="live-ticker-erste" class="scroll-mt-6">
                <div class="border-l-4 border-red-600 pl-4 mb-6">
                    <h2 class="text-2xl font-black uppercase tracking-tight text-gray-900">Live-Center: 1. Mannschaft</h2>
                    <p class="text-gray-500 text-sm">Aktuelle Daten direkt vom DFB (Fussball.de)</p>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Tabelle -->
                    <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm overflow-x-auto">
                        <h3 class="font-bold text-gray-700 mb-4 uppercase text-xs tracking-wider">Aktuelle Tabelle</h3>
                        <div id="wg-erste-tabelle"></div>
                        <!-- Hier den Tabellen-Scriptcode von Fussball.de reinwerfen: -->
                        <!-- <script type="text/javascript" src="https://www.fussball.de/widget2/-/schluessel/DEIN_SCHLUESSEL/target/wg-erste-tabelle"></script> -->
                        <p class="text-xs text-gray-400 italic p-4 text-center bg-gray-50 rounded">Tabelle wird geladen...</p>
                    </div>
                    <!-- Spielplan -->
                    <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm">
                        <h3 class="font-bold text-gray-700 mb-4 uppercase text-xs tracking-wider">Nächste Spiele & Ergebnisse</h3>
                        <div id="wg-erste-spielplan"></div>
                        <!-- Hier den Spielplan-Scriptcode von Fussball.de reinwerfen: -->
                        <!-- <script type="text/javascript" src="https://www.fussball.de/widget2/-/schluessel/DEIN_SCHLUESSEL/target/wg-erste-spielplan"></script> -->
                        <p class="text-xs text-gray-400 italic p-4 text-center bg-gray-50 rounded">Spielplan wird geladen...</p>
                    </div>
                </div>
            </div>

            <!-- Live-Bereich: 2. Mannschaft -->
            <div id="live-ticker-zweite" class="scroll-mt-6">
                <div class="border-l-4 border-zinc-900 pl-4 mb-6">
                    <h2 class="text-2xl font-black uppercase tracking-tight text-gray-900">Live-Center: 2. Mannschaft</h2>
                    <p class="text-gray-500 text-sm">Aktuelle Daten direkt vom DFB (Fussball.de)</p>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Tabelle -->
                    <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm overflow-x-auto">
                        <h3 class="font-bold text-gray-700 mb-4 uppercase text-xs tracking-wider">Aktuelle Tabelle</h3>
                        <div id="wg-zweite-tabelle"></div>
                        <!-- <script type="text/javascript" src="https://www.fussball.de/widget2/-/schluessel/DEIN_SCHLUESSEL/target/wg-zweite-tabelle"></script> -->
                        <p class="text-xs text-gray-400 italic p-4 text-center bg-gray-50 rounded">Tabelle wird geladen...</p>
                    </div>
                    <!-- Spielplan -->
                    <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm">
                        <h3 class="font-bold text-gray-700 mb-4 uppercase text-xs tracking-wider">Nächste Spiele & Ergebnisse</h3>
                        <div id="wg-zweite-spielplan"></div>
                        <!-- <script type="text/javascript" src="https://www.fussball.de/widget2/-/schluessel/DEIN_SCHLUESSEL/target/wg-zweite-spielplan"></script> -->
                        <p class="text-xs text-gray-400 italic p-4 text-center bg-gray-50 rounded">Spielplan wird geladen...</p>
                    </div>
                </div>
            </div>

        </div>
    </main>

</MainLayout>