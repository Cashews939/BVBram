---
import '../styles/global.css';
import logoImage from '../assets/wissen/logo.png';
import { Image } from 'astro:assets';

// Wir erlauben, dass jede Seite ihren eigenen Titel an das Layout übergibt
const { title } = Astro.props;
---

<html lang="de">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <!-- FIX 1: initial-scale=1 hinzugefügt für korrektes mobiles Skalieren -->
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | BV Brambauer 13/45 e.V.</title>
    </head>
    
    <body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col">

        <nav class="bg-white text-gray-900 sticky top-0 z-50 shadow-sm border-b border-gray-100">
            <!-- py-4 statt py-2 gibt auf Mobile etwas mehr Luft zum Atmen -->
            <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center gap-4 md:gap-0">
                
                <!-- Logo & Vereinsname: Zentriert sich auf Mobile automatisch -->
                <div class="flex items-center space-x-4">
                    <Image 
                        src={logoImage} 
                        alt="BV Brambauer-Lünen Logo" 
                        class="w-10 h-auto md:w-12 object-contain"
                        quality="max"
                    />
                    <span class="font-black text-lg md:text-xl tracking-tight text-black">BV Brambauer <span class="text-red-600">13/45</span></span>
                </div>
                
                <!-- FIX 2: Navigation bricht jetzt sauber um (flex-wrap) und zentriert sich auf Mobile -->
                <div class="w-full md:w-auto flex flex-wrap justify-center md:justify-end gap-x-6 gap-y-2 pt-2 md:pt-0 font-semibold text-xs uppercase tracking-wider border-t border-gray-100 md:border-t-0">
                    <a href="/" class="text-gray-600 hover:text-red-600 transition">Startseite</a>
                    <a href="/aktuelles" class="text-gray-600 hover:text-red-600 transition">Aktuelles</a>
                    <a href="/senioren" class="text-gray-600 hover:text-red-600 transition">Senioren</a>
                    <a href="/junioren" class="text-gray-600 hover:text-red-600 transition">Junioren</a>
                    <a href="/chronik" class="text-gray-600 hover:text-red-600 transition">Chronik</a>
					<a 
						href="https://www.11teamsports.com/de-de/clubshop/bv-brambauer-13-45-e-v/" 
						target="_blank" 
						rel="noopener noreferrer" 
						class="text-red-600 hover:text-red-700 transition font-bold flex items-center gap-1"
					>
						Clubshop 🛒
					</a>
                </div>

            </div>
        </nav>

        <!-- Der eigentliche Inhalt der Seiten -->
        <div class="flex-grow">
            <slot />
        </div>

        <footer class="bg-gray-950 text-gray-400 py-12 border-t border-gray-950 mt-auto">
            <!-- gap-8 sorgt auf Mobile für besseren Abstand zwischen Text und Social-Buttons -->
            <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8">
                
                <!-- FIX 3: items-center auf Mobile, linksbündig ab Desktop. flex-wrap für die Links -->
                <div class="flex flex-col items-center md:items-start gap-4 text-sm text-center md:text-left">
                    <p>© 2026 BV Brambauer 13/45 e.V. Alle Rechte vorbehalten.</p>
                    <div class="flex flex-wrap justify-center md:justify-start gap-4">
                        <a href="/impressum" class="hover:text-white transition">Impressum</a>
                        <a href="/datenschutz" class="hover:text-white transition">Datenschutz</a>
                        <a href="/kontakt" class="hover:text-white transition">Kontakt</a>
                    </div>
                </div>

                <div class="flex items-center gap-4 shrink-0">
                    <a 
                        href="https://www.facebook.com/p/BV-Brambauer-1345-100063477852848/?locale=de_DE" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="bg-gray-900 hover:bg-blue-600 hover:text-white p-3 rounded-full transition duration-300 group"
                        aria-label="BV Brambauer auf Facebook"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                    </a>

                    <a 
                        href="https://www.instagram.com/bv_brambauer/?hl=de" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="bg-gray-900 hover:bg-gradient-to-tr hover:from-purple-600 hover:to-pink-500 hover:text-white p-3 rounded-full transition duration-300 group"
                        aria-label="BV Brambauer auf Instagram"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
                    </a>
                </div>

            </div>
        </footer>

    </body>
</html>