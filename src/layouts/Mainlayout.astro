---
import '../styles/global.css';
import logoImage from '../assets/wissen/logo.png';
import { Image } from 'astro:assets';

// Wir erlauben, dass jede Seite ihren eigenen Titel an das Layout übergibt
const { title } = Astro.props;
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | BV Brambauer 13/45 e.V.</title>
	</head>
	
	<body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col">

		<nav class="bg-white text-gray-900 sticky top-0 z-50 shadow-sm border-b border-gray-100">
			<div class="max-w-6xl mx-auto px-4 py-2 flex flex-col md:flex-row justify-between items-center gap-2 md:gap-0">
				
				<div class="flex items-center space-x-4">
					<Image 
						src={logoImage} 
						alt="BV Brambauer-Lünen Logo" 
						class="w-10 h-auto md:w-12 object-contain"
						quality="max"
					/>
					<span class="font-black text-lg md:text-xl tracking-tight text-black">BV Brambauer <span class="text-red-600">13/45</span></span>
				</div>
				
				<div class="w-full md:w-auto overflow-x-auto no-scrollbar flex justify-start md:justify-end space-x-6 py-1 md:py-0 font-semibold text-xs uppercase tracking-wider border-t border-gray-50 md:border-t-0">
					<div class="flex space-x-6 px-2 md:px-0 min-w-max">
						<a href="/" class="text-gray-600 hover:text-red-600 transition">Startseite</a>
						<a href="/aktuelles" class="text-gray-600 hover:text-red-600 transition">Aktuelles</a>
						<a href="/senioren" class="text-gray-600 hover:text-red-600 transition">Senioren</a>
						<a href="/junioren" class="text-gray-600 hover:text-red-600 transition">Junioren</a>
						<a href="/chronik" class="text-gray-600 hover:text-red-600 transition">Chronik</a>
					</div>
				</div>

			</div>
		</nav>

		<slot />

		<footer class="bg-black text-gray-400 py-12 border-t border-gray-800">
			<div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
				
				<div class="flex flex-col lg:flex-row items-center gap-4 lg:gap-12 text-center lg:text-left">
					<p class="text-sm text-gray-500">
						&copy; 2026 BV Brambauer 13/45 e.V. Alle Rechte vorbehalten.
					</p>
					<div class="flex space-x-8 text-sm font-medium tracking-wide">
						<a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
						<a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
						<a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a>
					</div>
				</div>

				<div class="flex space-x-6">
					<a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-red-500 transition-colors" aria-label="Instagram">
						<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
						</svg>
					</a>
					<a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-red-500 transition-colors" aria-label="Facebook">
						<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
							<path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
						</svg>
					</a>
				</div>

			</div>
		</footer>

	</body>
</html>